<!-- pages/teacher-register/teacher-register.wxml - 家教端注册页 -->

<view class="container">
  <!-- Logo和标题 -->
  <view class="header">
    <image class="logo" src="/images/teacher-logo.png" mode="aspectFit"></image>
    <text class="title">家教端注册</text>
    <text class="subtitle">成为家教，开启您的教学之旅</text>
  </view>

  <!-- 注册表单 -->
  <view class="register-form card">
    <!-- 手机号输入 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 验证码输入 -->
    <view class="form-item">
      <text class="label">验证码</text>
      <view class="code-input-wrapper">
        <input 
          class="input-field code-input" 
          type="number" 
          placeholder="请输入验证码"
          maxlength="6"
          value="{{code}}"
          bindinput="onCodeInput"
        />
        <view 
          class="send-code-btn {{sending ? 'disabled' : ''}}"
          bindtap="sendCode"
        >
          {{countdown > 0 ? countdown + 's' : '发送验证码'}}
        </view>
      </view>
    </view>

    <!-- 密码输入 -->
    <view class="form-item">
      <text class="label">设置密码</text>
      <input 
        class="input-field" 
        type="password" 
        placeholder="请设置密码（至少6位）"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 确认密码 -->
    <view class="form-item">
      <text class="label">确认密码</text>
      <input 
        class="input-field" 
        type="password" 
        placeholder="请再次输入密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <!-- 注册按钮 -->
    <view class="register-btn" bindtap="handleRegister">
      立即注册
    </view>

    <!-- 登录链接 -->
    <view class="login-link">
      <text>已有账号？</text>
      <text class="link" bindtap="goToLogin">立即登录</text>
    </view>
  </view>
</view>