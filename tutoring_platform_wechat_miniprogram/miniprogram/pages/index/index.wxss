page {
  background-color: #050b17;
  overflow-x: hidden;
}

.container {
  min-height: 100vh;
  background: radial-gradient(ellipse at 20% 30%, #0c1222, #03060e);
  position: relative;
  overflow-x: hidden;
}

/* 星空背景层 - 闪烁动画 */
.star-bg {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.star {
  position: absolute;
  background-color: #fff;
  border-radius: 50%;
  box-shadow: 0 0 12rpx rgba(255, 255, 255, 0.8);
  opacity: 0;
  animation: twinkle infinite ease-in-out;
}

@keyframes twinkle {
  0% { opacity: 0; transform: scale(0.8);}
  50% { opacity: 1; transform: scale(1.2); box-shadow: 0 0 20rpx rgba(255, 220, 100, 0.9);}
  100% { opacity: 0; transform: scale(0.8);}
}

/* 主内容层 (浮在星空之上) */
.content {
  position: relative;
  z-index: 2;
  padding-bottom: 60rpx;
}

/* 头部区域 */
.header {
  padding: 70rpx 40rpx 30rpx;
  text-align: center;
  backdrop-filter: blur(2px);
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.4), 0 0 0 4rpx rgba(255, 215, 0, 0.3);
  background: rgba(255,255,240,0.2);
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: 800;
  color: #FFE6B0;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 240, 200, 0.9);
  letter-spacing: 2rpx;
  font-weight: 400;
  background: rgba(0,0,0,0.3);
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 60rpx;
  backdrop-filter: blur(8px);
}

/* 特色网格 (玻璃质感) */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 20rpx 36rpx 30rpx;
}

.feature-card {
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(12px);
  border-radius: 32rpx;
  padding: 28rpx 12rpx 20rpx;
  text-align: center;
  transition: all 0.25s ease;
  border: 1rpx solid rgba(255, 215, 150, 0.35);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.feature-card:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.2);
  border-color: rgba(255, 210, 100, 0.7);
}

.feature-icon {
  font-size: 52rpx;
  margin-bottom: 16rpx;
  filter: drop-shadow(0 4rpx 6rpx rgba(0,0,0,0.3));
}

.feature-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFEFCF;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: rgba(255, 245, 220, 0.8);
  line-height: 1.3;
  display: block;
}

/* 荣誉标签墙 */
.honor-section {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx 36rpx;
  gap: 20rpx;
  margin: 16rpx 0 8rpx;
}

.honor-tag {
  background: linear-gradient(115deg, rgba(30, 40, 70, 0.8), rgba(20, 25, 55, 0.9));
  backdrop-filter: blur(8px);
  border-radius: 60rpx;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  color: #FFE6B0;
  font-weight: 500;
  border: 1rpx solid rgba(255, 200, 100, 0.6);
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.3);
  transition: all 0.2s;
  letter-spacing: 1rpx;
}

.honor-tag:active {
  transform: scale(0.96);
  background: linear-gradient(115deg, rgba(80, 100, 150, 0.9), rgba(50, 60, 100, 1));
  border-color: #FFD966;
}

/* 入口卡片区域 */
.entry-buttons {
  padding: 20rpx 36rpx;
}

.entry-card {
  background: rgba(30, 35, 55, 0.75);
  backdrop-filter: blur(16px);
  border-radius: 36rpx;
  padding: 32rpx 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 16rpx 32rpx rgba(0, 0, 0, 0.3);
  transition: all 0.25s ease;
  border: 1rpx solid rgba(255, 215, 140, 0.4);
}

.entry-hover {
  transform: scale(0.98);
  background: rgba(50, 60, 90, 0.9);
  border-color: #FFCF8A;
}

.parent-entry {
  border-left: 10rpx solid #6EE7B7;
  border-left-width: 10rpx;
}

.teacher-entry {
  border-left: 10rpx solid #60A5FA;
  border-left-width: 10rpx;
}

.entry-icon {
  width: 100rpx;
  height: 100rpx;
  margin-right: 30rpx;
  background: rgba(255,255,210,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.entry-icon image {
  width: 70rpx;
  height: 70rpx;
}

.entry-content {
  flex: 1;
}

.entry-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: #FFF2DD;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
}

.entry-desc {
  display: block;
  font-size: 24rpx;
  color: #CFE0FF;
}

.entry-arrow {
  font-size: 56rpx;
  color: #FFD966;
  margin-left: 20rpx;
  font-weight: 300;
}

/* 手风琴问答区域 */
.qa-section {
  margin: 32rpx 36rpx 50rpx;
  background: rgba(10, 18, 30, 0.65);
  backdrop-filter: blur(20rpx);
  border-radius: 48rpx;
  padding: 32rpx 28rpx;
  border: 1rpx solid rgba(255, 210, 120, 0.4);
  box-shadow: 0 20rpx 40rpx rgba(0, 0, 0, 0.3);
}

.section-title {
  text-align: center;
  margin-bottom: 36rpx;
}

.title-text {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #FFE1A0;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.4);
}

.title-sub {
  font-size: 24rpx;
  color: #B9D0FF;
  display: block;
  margin-top: 8rpx;
}

.qa-item {
  margin-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255, 230, 160, 0.2);
  padding-bottom: 12rpx;
}

.qa-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 12rpx 18rpx;
  background: rgba(255, 245, 210, 0.05);
  border-radius: 28rpx;
  transition: background 0.2s;
  cursor: pointer;
}

.qa-question:active {
  background: rgba(255, 235, 170, 0.15);
}

.question-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #FCE6B4;
  width: 80%;
  line-height: 1.4;
}

.qa-icon {
  font-size: 48rpx;
  font-weight: 500;
  color: #FFD966;
  width: 60rpx;
  text-align: center;
}

.qa-answer {
  font-size: 28rpx;
  line-height: 1.55;
  color: #E0EDFF;
  background: rgba(0, 0, 0, 0.3);
  padding: 28rpx 28rpx;
  border-radius: 28rpx;
  margin-top: 10rpx;
  margin-bottom: 10rpx;
  border-left: 6rpx solid #FFC857;
  letter-spacing: 1rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 30rpx 30rpx 50rpx;
  margin-top: 10rpx;
}

.footer-text {
  font-size: 24rpx;
  color: #BFD4FF;
  display: block;
  letter-spacing: 2rpx;
  background: rgba(0,0,0,0.3);
  padding: 12rpx 20rpx;
  border-radius: 60rpx;
  width: fit-content;
  margin: 0 auto 12rpx;
  backdrop-filter: blur(4px);
}

.footer-sub {
  font-size: 22rpx;
  color: #98abdd;
  display: block;
}