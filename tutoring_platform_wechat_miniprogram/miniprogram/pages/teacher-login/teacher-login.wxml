<!-- pages/teacher-login/teacher-login.wxml - 家教端登录页 -->
<!-- 微信小程序开发注意点：
     1. 表单输入使用 bindinput 绑定事件
     2. 按钮点击使用 bindtap
     3. 微信登录使用 wx.login + 云函数
-->

<view class="container">
  <!-- Logo和标题 -->
  <view class="header">
    <image class="logo" src="/images/teacher-logo.png" mode="aspectFit"></image>
    <text class="title">家教端登录</text>
    <text class="subtitle">欢迎回来，开始您的家教之旅</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form card">
    <!-- 手机号输入 -->
    <view class="form-item">
      <text class="label">手机号</text>
      <input 
        class="input-field" 
        type="number" 
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <!-- 密码输入 -->
    <view class="form-item">
      <text class="label">密码</text>
      <input 
        class="input-field" 
        type="password" 
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <!-- 忘记密码链接 -->
    <view class="forgot-password" bindtap="goToResetPassword">
      忘记密码？
    </view>

    <!-- 登录按钮 -->
    <view class="login-btn" bindtap="handleLogin">
      登录
    </view>

    <!-- 分隔线 -->
    <view class="divider">
      <text>或</text>
    </view>

    <!-- 微信一键登录 -->
    <view class="wechat-login-btn" bindtap="handleWechatLogin">
      <image class="wechat-icon" src="/images/wechat-icon.png" mode="aspectFit"></image>
      <text>微信一键登录</text>
    </view>

    <!-- 注册链接 -->
    <view class="register-link">
      <text>还没有账号？</text>
      <text class="link" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
</view>