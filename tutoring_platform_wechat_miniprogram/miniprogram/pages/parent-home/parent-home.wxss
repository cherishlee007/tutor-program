/* pages/parent-home/parent-home.wxss - 家长端主页样式 */

.container {
  min-height: 100vh;
  background: #f8fafc;
}

/* 搜索栏样式 */
.search-bar {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  margin-right: 20rpx;
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.filter-btn {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 26rpx;
}

.filter-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

/* 筛选面板样式 */
.filter-panel {
  background: white;
  margin: 20rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.filter-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.reset-btn {
  font-size: 26rpx;
  color: #4CAF50;
}

.filter-item {
  margin-bottom: 30rpx;
}

.filter-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.filter-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-option {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.filter-option.active {
  background: #e8f5e8;
  color: #4CAF50;
  border-color: #4CAF50;
}

.picker-value {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
}

.time-input {
  padding: 12rpx 24rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.apply-filter-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: white;
  padding: 20rpx;
  border-radius: 50rpx;
  text-align: center;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 教员列表样式 */
.teacher-list {
  padding: 20rpx;
}

.waterfall-container {
  display: flex;
  gap: 20rpx;
}

.waterfall-column {
  flex: 1;
}

.teacher-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  position: relative;
  transition: all 0.3s ease;
}

.teacher-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.status-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: #f44336;
  color: white;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.card-header {
  margin-bottom: 16rpx;
}

.teacher-id {
  font-size: 24rpx;
  color: #999;
}

/* 这里全部改成了小程序支持的平级写法 */
.card-body .info-row {
  display: flex;
  margin-bottom: 12rpx;
}
.card-body .info-row:last-child {
  margin-bottom: 0;
}
.card-body .label {
  font-size: 26rpx;
  color: #666;
  min-width: 80rpx;
}
.card-body .value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}
.card-body .salary {
  color: #ff6b35;
  font-weight: 600;
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 20rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
}

.load-more text {
  color: #4CAF50;
  font-size: 28rpx;
}