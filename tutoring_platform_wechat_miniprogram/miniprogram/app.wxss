/**app.wxss - 全局样式**/

/* 全局重置 */
page {
  background-color: #f5f9ff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 渐变背景 */
.gradient-bg {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 卡片样式 */
.card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
}

.btn-secondary {
  background: white;
  color: #667eea;
  border: 1rpx solid #667eea;
  border-radius: 12rpx;
}

/* 文本样式 */
.text-primary {
  color: #667eea;
}

.text-success {
  color: #52c41a;
}

.text-warning {
  color: #faad14;
}

.text-danger {
  color: #ff4d4f;
}

.text-muted {
  color: #999;
}

/* 状态标签 */
.status-badge {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.status-available {
  background: #e6f7ff;
  color: #1890ff;
}

.status-taken {
  background: #fff1f0;
  color: #ff4d4f;
}

/* 加载状态 */
.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 表单样式 */
.form-item {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: 1rpx solid #e9ecef;
}

.form-input:focus {
  border-color: #667eea;
  background: white;
}

/* 瀑布流布局 */
.waterfall {
  column-count: 2;
  column-gap: 20rpx;
  padding: 20rpx;
}

.waterfall-item {
  break-inside: avoid;
  margin-bottom: 20rpx;
}

/* 响应式适配 */
@media (max-width: 750rpx) {
  .container {
    padding: 0 20rpx;
  }
}